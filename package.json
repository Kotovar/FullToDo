{
  "name": "fulltodo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "prepare": "husky",
    "install:all": "npm install",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "dev": "sh scripts/dev.sh",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "stop:docker": "docker compose stop",
    "stats": "bash scripts/count-lines.sh",
    "check:size": "node scripts/check-file-size.mts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
