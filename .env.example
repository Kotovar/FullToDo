DB_TYPE=postgres # mongo / postgres / mock
SERVER_TYPE=http # express / http / nextJs
PORT=5000
VITE_URL=http://localhost:${PORT}
NODE_ENV=development

DB_USER='postgres'
DB_PASSWORD='secret'
DB_HOST='localhost'
DB_PORT=5432
DB_NAME='fulltodo'

EMAIL_TOKEN_SECRET='сделать_токен'
ACCESS_TOKEN_SECRET="сделать_токен"
REFRESH_TOKEN_SECRET="сделать_токен"
GOOGLE_CLIENT_ID='получить_ID'
VITE_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET='получить_SECRET'

EMAIL_PROVIDER=mailtrap # mailtrap / resend
# For Resend local testing:
# EMAIL_FROM='FullToDo <onboarding@resend.dev>'
# For Mailtrap sandbox:
EMAIL_FROM='FullToDo <noreply@fulltodo.dev>'

# Mailtrap Sandbox: https://mailtrap.io/home
MAILTRAP_USER=""
MAILTRAP_PASS=""

# Resend API: https://resend.com/emails
RESEND_API_KEY=""

CORS_ORIGIN="http://localhost:5173"

REDIS_HOST=localhost
REDIS_PORT=6379
