{
  "name": "fulltodo_backend",
  "version": "0.0.0",
  "main": "src/app.ts",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/app.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/app.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register src/app.ts"
  },
  "keywords": [],
  "author": "Kotovar",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "shared": "file:../shared"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "^0.27.5",
    "@eslint/js": "^10.0.1",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
