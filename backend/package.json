{
  "name": "fulltodo_backend",
  "version": "1.1.0",
  "main": "src/app.ts",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/app.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/app.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "lint-staged": "lint-staged",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register src/app.ts",
    "migrate": "ts-node -r tsconfig-paths/register src/db/postgres/migrate.ts",
    "email": "email dev --dir src/emails",
    "stats": "cd .. && npm run stats",
    "check:size": "node ../scripts/check-file-size.mts --no-exit-code"
  },
  "keywords": [],
  "author": "Kotovar",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.8",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.2",
    "shared": "file:../shared",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.24",
    "@react-email/ui": "^6.3.3",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "react-email": "^6.3.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
